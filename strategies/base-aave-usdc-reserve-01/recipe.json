  ],
  "actions": [
    {
      "action_id": "approve_usdc",
      "calls": [
        {
          "role": "usdc",
          "function": "approve"
        }
      ],
      "preconditions": [
        "wallet_usdc_balance_gte_requested_approval_amount"
