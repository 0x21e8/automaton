      "calls": [
        {
          "role": "aave_pool",
          "function": "withdraw"
        }
      ],
      "preconditions": [
        "aave_usdc_position_gte_requested_exit_amount"
      ],
      "postconditions": [
        "wallet_usdc_delta_positive_expected",
