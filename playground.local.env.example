# Copy this file to `playground.local.env` and edit the values for your machine.
# `npm run playground:dev` sources it as a shell env file before bootstrapping.

# Required when PLAYGROUND_REQUIRE_FORK=1, which is the default local playground mode.
LOCAL_EVM_FORK_URL=https://base-mainnet.example.invalid/v2/replace-me

# Optional advanced override; defaults to the imported runtime component.
AUTOMATON_COMPONENT_ROOT=/absolute/path/to/automaton-launchpad/components/ic-automaton

# The playground builds the imported canister artifact and prefers
# the workspace `target/wasm32-wasip1/release/backend_nowasi.wasm`.
# Set CHILD_WASM_PATH only when you want to pin a different artifact.
# CHILD_WASM_PATH=/absolute/path/to/backend_nowasi.wasm

# Optional: defaults to `git -C "$AUTOMATON_COMPONENT_ROOT" rev-parse HEAD` when omitted.
# CHILD_VERSION_COMMIT=0123456789abcdef0123456789abcdef01234567

# Optional unless the child should use the OpenRouter proxy worker path.
# FACTORY_CHILD_INFERENCE_PROXY_WORKER_BASE_URL=https://proxy.example.com
# FACTORY_CHILD_INFERENCE_PROXY_TRUSTED_CALLBACK_PRINCIPAL=aaaaa-aa

# Optional local overrides.
# PLAYGROUND_BUILD_CHILD_ARTIFACT=1
# PLAYGROUND_REQUIRE_FORK=0
# PLAYGROUND_CHAIN_ID=20260326
# PLAYGROUND_CHAIN_NAME=Automaton Playground
# PLAYGROUND_ENV_LABEL=Automaton Playground
# PLAYGROUND_FACTORY_TOP_UP_AMOUNT=100000t
# WEB_HOST=127.0.0.1
# WEB_PORT=5173
