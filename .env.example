# Copy this file to `.env` at the repo root when using the local evaluation harness.
# The evaluator backend loads these values automatically from `.env`.

# Required: steward address used for all automaton spawn sessions in an evaluation run.
EVAL_STEWARD_ADDRESS=0x0000000000000000000000000000000000000000

# Required: OpenRouter API key used for automaton provider config during spawn.
EVAL_OPENROUTER_API_KEY=replace-with-openrouter-api-key

# Optional: only needed when your experimented strategies require Brave Search.
EVAL_BRAVE_SEARCH_API_KEY=

# Optional unless an evaluation automaton uses `transport: openrouter_proxy_worker`.
# These values are also forwarded into the local factory child runtime during evaluator bootstrap.
EVAL_INFERENCE_PROXY_WORKER_BASE_URL=
EVAL_INFERENCE_PROXY_TRUSTED_CALLBACK_PRINCIPAL=

# Optional override: only set these if the local factory child runtime should use different
# proxy settings than the evaluator.
FACTORY_CHILD_INFERENCE_PROXY_WORKER_BASE_URL=
FACTORY_CHILD_INFERENCE_PROXY_TRUSTED_CALLBACK_PRINCIPAL=

# Required in the default local playground flow: upstream Base RPC used for the local fork.
LOCAL_EVM_FORK_URL=https://base-mainnet.example.invalid/v2/replace-me

# Optional advanced override; defaults to the imported runtime component.
AUTOMATON_COMPONENT_ROOT=/absolute/path/to/automaton-launchpad/components/ic-automaton
