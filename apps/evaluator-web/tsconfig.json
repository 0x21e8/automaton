{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@ic-automaton/shared": [
        "packages/shared/src/index.ts"
      ],
      "@ic-automaton/ui": [
        "packages/ui/src/generated/tokens.ts"
      ]
    },
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "types": [
      "vite/client",
      "vitest/globals"
    ],
    "noEmit": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "vite.config.ts"
  ]
}
