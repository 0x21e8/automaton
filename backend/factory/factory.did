type AddRepositoryStrategyRequest = record {
  metadata : RepositoryStrategyMetadata;
  recipe_json : text;
};
type ArtifactUploadStatus = record {
  in_progress : bool;
  total_size_bytes : opt nat64;
  version_commit : opt text;
  expected_sha256 : opt text;
  received_size_bytes : nat64;
};
type AutomatonBootstrapEvidence = record {
  evm_address : opt text;
  bootstrap_parent_id : opt text;
  bootstrap_factory_principal : opt principal;
  bootstrap_constitution_hash : opt text;
  bootstrap_strategies : vec text;
  bootstrap_contract_version : opt nat16;
  steward_chain_id : opt nat64;
  bootstrap_session_id : opt text;
  bootstrap_name : opt text;
  bootstrap_risk : opt nat8;
  bootstrap_skills : vec text;
  bootstrap_version_commit : opt text;
  steward_enabled : opt bool;
  // Present only while a birth is in flight. Cleared after successful release.
  bootstrap_constitution : opt text;
  steward_address : opt text;
};
type AutomatonBootstrapVerification = record {
  failures : vec text;
  evidence : AutomatonBootstrapEvidence;
  checked_at : nat64;
  passed : bool;
};
type AutomatonChildRuntimeConfig = record {
  evm_chain_id : opt nat64;
  evm_confirmation_depth : opt nat64;
  evm_rpc_url : opt text;
  ecdsa_key_name : opt text;
  llm_canister_id : opt principal;
  auto_topup_cycle_threshold : opt nat64;
  cycle_topup_enabled : opt bool;
  inbox_contract_address : opt text;
  inference_proxy_trusted_callback_principal : opt text;
  inference_proxy_worker_base_url : opt text;
  search_api_key : opt text;
  evm_bootstrap_lookback_blocks : opt nat64;
  http_allowed_domains : opt vec text;
};
type AutomatonRuntimeState = record {
  model : opt text;
  bootstrap_verification : opt AutomatonBootstrapVerification;
  evm_address : text;
  funded_amount : text;
  session_id : text;
  chain : SpawnChain;
  risk : nat8;
  last_funded_at : opt nat64;
  canister_id : text;
  initialized_at : nat64;
  evm_address_derived_at : opt nat64;
  provider_keys_cleared : bool;
  controller_handoff_completed_at : opt nat64;
  install_succeeded_at : opt nat64;
  skills : vec text;
  steward_address : text;
  strategies : vec text;
};
type CreateReproductionSessionRequest = record {
  // Child-side preflight telemetry only. Factory admission ignores this as
  // authority and reads the parent's ERC-20 balance through its own RPC.
  observed_liquid_usdc_raw : text;
  memory_dowry : vec MemoryDowryFact;
  name : text;
  child_constitution : text;
  inherited_strategy_stats : vec InheritedStrategyStat;
  parent_constitution : text;
  gross_amount : text;
};
type CreateSpawnSessionRequest = record {
  asset : SpawnAsset;
  // Optional on the wire so pre-v2 callers and stable in-flight sessions decode.
  // New session creation requires both fields and validates them before persistence.
  name : opt text;
  parent_id : opt text;
  constitution : opt text;
  provider_secrets : SpawnProviderSecrets;
  config : SpawnConfig;
  steward_address : text;
  gross_amount : text;
};
type CreateSpawnSessionResponse = record {
  quote : SpawnQuote;
  session : SpawnSession;
};
type CreationCostQuote = record { updated_at : nat64; usdc_cost : text };
type DeprecateRepositoryStrategyRequest = record {
  strategy_id : text;
  reason : opt text;
};
type EscrowClaim = record {
  updated_at : nat64;
  asset : SpawnAsset;
  session_id : text;
  claim_id : text;
  required_gross_amount : text;
  chain : SpawnChain;
  quote_terms_hash : text;
  paid_amount : text;
  created_at : nat64;
  payment_status : PaymentStatus;
  refundable : bool;
  refunded_at : opt nat64;
  refund_broadcast : opt ReleaseBroadcastRecord;
  payment_address : text;
  last_scanned_block : opt nat64;
};
type FactoryArtifactSnapshot = record {
  loaded : bool;
  wasm_sha256 : opt text;
  wasm_size_bytes : opt nat64;
  version_commit : opt text;
};
type FactoryConfigSnapshot = record {
  base_rpc_fallback_endpoint : opt text;
  escrow_contract_address : text;
  session_ttl_ms : nat64;
  cycles_per_spawn : nat64;
  child_runtime : AutomatonChildRuntimeConfig;
  release_broadcast_config : ReleaseBroadcastConfig;
  wasm_sha256 : opt text;
  version_commit : text;
  fee_config : FeeConfig;
  creation_cost_quote : CreationCostQuote;
  factory_evm_address : opt text;
  base_rpc_endpoint : opt text;
  pause : bool;
  estimated_outcall_cycles_per_interval : nat64;
  payment_address : text;
  min_pool_balance : nat64;
};
type FactoryError = variant {
  QuoteTermsHashMismatch : record { expected : text; received : text };
  RoomMessageBodyTooLarge : record {
    max_bytes : nat64;
    provided_bytes : nat64;
  };
  RepositoryStrategyDeprecated : record { strategy_id : text };
  RegistryRecordNotFound : record { canister_id : text };
  InvalidAmount : record { value : text };
  ReproductionIneligible : record { reason : text };
  UnauthorizedAdmin : record { caller : text };
  RepositoryStrategyRevoked : record { strategy_id : text };
  TooManyRoomMentions : record { max_mentions : nat64; provided : nat64 };
  RpcRequestFailed : record {
    endpoint : text;
    code : opt int64;
    message : text;
    operation : text;
    category : RpcFailureCategory;
  };
  SessionNotRetryable : record { session_id : text; state : SpawnSessionState };
  InvalidReproduction : record { reason : text };
  ArtifactUploadIncomplete : record { expected : nat64; received : nat64 };
  InsufficientCyclesForOperation : record {
    available : nat;
    operation : text;
    required : nat;
  };
  ManagementCallFailed : record { method : text; message : text };
  InvalidChildRuntimeConfig : record { field : text; message : text };
  InvalidDeathReport : record { reason : text };
  SessionNotFound : record { session_id : text };
  InvalidStewardProof : record { reason : text };
  RepositoryStrategyAlreadyExists : record { strategy_id : text };
  ControllerInvariantViolation : record { canister_id : text };
  InvalidSha256 : record { value : text };
  RepositoryStrategyIncompatibleChain : record {
    strategy_id : text;
    requested_chain : SpawnChain;
  };
  UnauthorizedReproduction : record { caller : text };
  InsufficientCyclesPool : record { available : nat; required : nat };
  RepositoryStrategyNotFound : record { strategy_id : text };
  AutomatonBootstrapVerificationFailed : record {
    failures : vec text;
    canister_id : text;
  };
  UnauthorizedRoomPoster : record { caller : text };
  NoPendingArtifactUpload;
  ArtifactUploadTooLarge : record { attempted : nat64; expected : nat64 };
  InvalidRoomContentType : record { value : text };
  ArtifactHashMismatch : record { actual : text; expected : text };
  FactoryPaused : record { pause : bool };
  IllegalSessionTransition : record {
    session_id : text;
    event : text;
    from_state : SpawnSessionState;
  };
  UnauthorizedSteward : record { session_id : text; caller : text };
  PaymentNotSettled : record { status : PaymentStatus; session_id : text };
  SessionNotRefundable : record {
    session_id : text;
    payment_status : PaymentStatus;
    state : SpawnSessionState;
  };
  MissingChildRuntimeConfig : record { field : text };
  GrossBelowRequiredMinimum : record { provided : text; required : text };
  AutomatonRuntimeNotFound : record { canister_id : text };
  InvalidPaginationLimit : record { limit : nat64 };
  SessionNotReadyForSpawn : record {
    session_id : text;
    state : SpawnSessionState;
  };
  SessionExpired : record { session_id : text; expires_at : nat64 };
  InvalidRoomMessageJson : record { message : text };
  InvalidVersionCommit : record { value : text };
  InvalidRepositoryStrategy : record { field : text; message : text };
  EmptyRoomMessageBody;
  EscrowClaimNotFound : record { session_id : text };
};
type FactoryHealthSnapshot = record {
  scheduler : FactorySchedulerHealthSnapshot;
  current_canister_balance : nat;
  escrow_contract_address : text;
  cycles_per_spawn : nat64;
  artifact : FactoryArtifactSnapshot;
  active_sessions : FactorySessionHealthCounts;
  factory_evm_address : opt text;
  pause : bool;
  estimated_outcall_cycles_per_interval : nat64;
  min_pool_balance : nat64;
};
type FactoryInitArgs = record {
  base_rpc_fallback_endpoint : opt text;
  escrow_contract_address : opt text;
  session_ttl_ms : opt nat64;
  cycles_per_spawn : opt nat64;
  child_runtime : opt AutomatonChildRuntimeConfig;
  release_broadcast_config : opt ReleaseBroadcastConfig;
  wasm_sha256 : opt text;
  version_commit : opt text;
  fee_config : opt FeeConfig;
  creation_cost_quote : opt CreationCostQuote;
  base_rpc_endpoint : opt text;
  pause : bool;
  estimated_outcall_cycles_per_interval : opt nat64;
  payment_address : opt text;
  min_pool_balance : opt nat64;
  admin_principals : vec principal;
};
type FactoryOperationalConfig = record {
  cycles_per_spawn : nat64;
  estimated_outcall_cycles_per_interval : nat64;
  min_pool_balance : nat64;
};
type FactoryRuntimeSnapshot = record {
  scheduler : FactorySchedulerHealthSnapshot;
  failed_jobs : vec SchedulerJob;
  retry_queue : vec SchedulerJob;
  recent_jobs : vec SchedulerJob;
  active_jobs : vec SchedulerJob;
};
type FactorySchedulerHealthSnapshot = record {
  last_tick_finished_ms : opt nat64;
  last_tick_error : opt text;
  last_tick_started_ms : opt nat64;
  job_counts : FactorySchedulerJobCounts;
  retry_queue_count : nat64;
  active_job_ids : vec text;
};
type FactorySchedulerJobCounts = record {
  total : nat64;
  pending : nat64;
  skipped : nat64;
  with_last_error : nat64;
  completed : nat64;
  running : nat64;
  terminal : nat64;
  backoff : nat64;
};
type FactorySessionHealthCounts = record {
  retryable_failed : nat64;
  broadcasting_release : nat64;
  awaiting_payment : nat64;
  spawning : nat64;
  payment_detected : nat64;
};
type FactoryStewardCommand = variant {
  RetrySpawnSession : record { session_id : text };
  ClaimSpawnRefund : record { session_id : text };
};
type FactoryStewardCommandResult = variant {
  Refund : RefundSpawnResponse;
  Retry : SpawnSessionStatusResponse;
};
type FactoryStewardProof = record {
  signature : text;
  command_hash : text;
  chain_id : nat64;
  address : text;
  nonce : nat64;
  expires_at_ns : nat64;
};
type FactoryStewardProofTemplate = record {
  command_hash : text;
  chain_id : nat64;
  signing_payload : text;
  address : text;
  nonce : nat64;
  expires_at_ns : nat64;
};
type FeeConfig = record { usdc_fee : text; updated_at : nat64 };
type GetRepositoryStrategyResponse = record {
  updated_at : nat64;
  item : opt RepositoryStrategyRecord;
};
type InferenceTransport = variant { OpenrouterDirect; OpenrouterProxyWorker };
type InheritedStrategyStat = record {
  protocol : text;
  primitive : text;
  total_runs : nat64;
  nondeterministic_failures : nat64;
  template_id : text;
  chain_id : nat64;
  success_runs : nat64;
  deterministic_failures : nat64;
};
type ListRepositoryStrategiesResponse = record {
  updated_at : nat64;
  items : vec RepositoryStrategyRecord;
};
type MemoryDowryFact = record { key : text; value : text };
type OpenRouterReasoningLevel = variant { Low; High; Medium; Default };
type PaymentStatus = variant { Refunded; Paid; Unpaid; Partial };
type PostRoomMessageRequest = record {
  body : text;
  content_type : opt RoomContentType;
  mentions : opt vec text;
};
type ProviderConfig = record {
  open_router_reasoning_level : OpenRouterReasoningLevel;
  model : opt text;
  inference_transport : InferenceTransport;
};
type RecordInfrastructureDeathRequest = record {
  canister_id : text;
  estate_disposition : text;
  incident_reference : text;
};
type RefundSpawnResponse = record {
  session_id : text;
  refund_tx_hash : opt text;
  payment_status : PaymentStatus;
  state : SpawnSessionState;
  refunded_at : nat64;
};
type ReleaseBroadcastConfig = record {
  ecdsa_key_name : text;
  max_priority_fee_per_gas : nat64;
  max_fee_per_gas : nat64;
  chain_id : nat64;
  gas_limit : nat64;
};
type ReleaseBroadcastFailure = record {
  rpc_code : opt int64;
  occurred_at : nat64;
  rpc_endpoint : opt text;
  stage : ReleaseBroadcastStage;
  message : text;
  rpc_category : opt RpcFailureCategory;
};
type ReleaseBroadcastRecord = record {
  last_error : opt ReleaseBroadcastFailure;
  signature : opt ReleaseSignatureRecord;
  rpc_tx_hash : opt text;
  raw_transaction_hex : opt text;
  ecdsa_key_name : opt text;
  escrow_contract_address : text;
  claim_id : text;
  max_priority_fee_per_gas : nat64;
  recipient : text;
  max_fee_per_gas : nat64;
  chain_id : nat64;
  broadcast_at : opt nat64;
  nonce : nat64;
  signing_payload_hash : opt text;
  gas_limit : nat64;
  raw_transaction_hash : opt text;
  calldata_hex : text;
};
type ReleaseBroadcastStage = variant {
  Signing;
  SignatureRecovery;
  RawTransactionConstruction;
  RpcBroadcast;
  ReceiptConfirmation;
  SigningPayloadConstruction;
  CalldataEncoding;
  PublicKeyLookup;
};
type ReleaseSignatureRecord = record { r : text; s : text; y_parity : bool };
type ReportDeathRequest = record {
  cause : text;
  terminal_turn_id : text;
  estate_disposition : text;
};
type RepositoryStrategyMetadata = record {
  protocol : text;
  canonical_chain : SpawnChain;
  primitive : text;
  source : RepositoryStrategySource;
  name : text;
  description : text;
  canonical_chain_id : nat64;
  compatible_spawn_chains : vec SpawnChain;
  strategy_id : text;
};
type RepositoryStrategyMutationResponse = record {
  strategy : RepositoryStrategyRecord;
};
type RepositoryStrategyRecord = record {
  status : RepositoryStrategyStatus;
  updated_at : nat64;
  deprecated_at : opt nat64;
  metadata : RepositoryStrategyMetadata;
  created_at : nat64;
  revoked_at : opt nat64;
  recipe_json : text;
};
type RepositoryStrategySessionSnapshot = record {
  protocol : text;
  canonical_chain : SpawnChain;
  primitive : text;
  selected_at : nat64;
  source : RepositoryStrategySource;
  name : text;
  description : text;
  canonical_chain_id : nat64;
  strategy_id : text;
  resolved_chain_id : opt nat64;
  recipe_json : text;
  requested_spawn_chain : SpawnChain;
  source_status : RepositoryStrategyStatus;
};
type RepositoryStrategySource = record {
  source_path : text;
  source_commit : text;
};
type RepositoryStrategyStatus = variant { Active; Deprecated; Revoked };
type ReproductionEligibility = record {
  observed_at_ms : nat64;
  parent_created_at_ms : nat64;
  cooldown_ends_at_ms : opt nat64;
  eligible : bool;
  minimum_age_at_ms : nat64;
  reason : opt text;
};
type ReproductionPolicy = record {
  progenitor_royalty_bps : nat16;
  terminal_reserve_usdc_raw : text;
  min_endowment_usdc_raw : text;
  cooldown_ms : nat64;
  max_constitution_edit_distance_bps : nat16;
  topup_reserve_usdc_raw : text;
  royalty_depth : nat8;
  min_age_ms : nat64;
  parent_royalty_bps : nat16;
  inference_reserve_usdc_raw : text;
};
type Result = variant {
  Ok : RepositoryStrategyMutationResponse;
  Err : FactoryError;
};
type Result_1 = variant { Ok : nat64; Err : FactoryError };
type Result_10 = variant { Ok : SessionAdminView; Err : FactoryError };
type Result_11 = variant {
  Ok : SpawnSessionStatusResponse;
  Err : FactoryError;
};
type Result_12 = variant { Ok : SpawnedAutomatonRecord; Err : FactoryError };
type Result_13 = variant { Ok : RoomMessagePage; Err : FactoryError };
type Result_14 = variant {
  Ok : SpawnedAutomatonRegistryPage;
  Err : FactoryError;
};
type Result_15 = variant { Ok : RoomMessage; Err : FactoryError };
type Result_16 = variant {
  Ok : FactoryStewardProofTemplate;
  Err : FactoryError;
};
type Result_17 = variant {
  Ok : AutomatonChildRuntimeConfig;
  Err : FactoryError;
};
type Result_18 = variant { Ok : CreationCostQuote; Err : FactoryError };
type Result_19 = variant { Ok : FeeConfig; Err : FactoryError };
type Result_2 = variant { Ok : ArtifactUploadStatus; Err : FactoryError };
type Result_20 = variant { Ok : FactoryOperationalConfig; Err : FactoryError };
type Result_21 = variant { Ok : bool; Err : FactoryError };
type Result_22 = variant { Ok : ReleaseBroadcastConfig; Err : FactoryError };
type Result_3 = variant { Ok : FactoryArtifactSnapshot; Err : FactoryError };
type Result_4 = variant { Ok : CreateSpawnSessionResponse; Err : FactoryError };
type Result_5 = variant { Ok : text; Err : FactoryError };
type Result_6 = variant {
  Ok : FactoryStewardCommandResult;
  Err : FactoryError;
};
type Result_7 = variant { Ok : FactoryConfigSnapshot; Err : FactoryError };
type Result_8 = variant { Ok : FactoryRuntimeSnapshot; Err : FactoryError };
type Result_9 = variant { Ok : ReproductionEligibility; Err : FactoryError };
type RevokeRepositoryStrategyRequest = record {
  strategy_id : text;
  reason : opt text;
};
type RoomContentType = variant { ApplicationJson; TextPlain };
type RoomMessage = record {
  seq : nat64;
  body : text;
  content_type : RoomContentType;
  created_at : nat64;
  author_canister_id : text;
  mentions : vec text;
  message_id : text;
};
type RoomMessagePage = record {
  messages : vec RoomMessage;
  latest_seq : opt nat64;
  next_after_seq : opt nat64;
};
type RoyaltyAllocation = record {
  source : text;
  recipient : text;
  amount : text;
  depth : nat8;
};
type RpcFailureCategory = variant {
  ResponseTooLarge;
  Upstream;
  MalformedResponse;
  RateLimited;
  Unavailable;
  Transport;
};
type SchedulerFailureAction = variant { Skip; Retry; Backoff; Terminal };
type SchedulerFailureSource = variant {
  MissingConfig;
  InvalidConfig;
  Deterministic;
  Transient;
};
type SchedulerJob = record {
  last_error : opt SchedulerJobFailure;
  status : SchedulerJobStatus;
  leased_at_ms : opt nat64;
  kind : SchedulerJobKind;
  attempt_count : nat32;
  success_count : nat32;
  job_id : text;
  consecutive_failure_count : nat32;
  last_started_at_ms : opt nat64;
  last_finished_at_ms : opt nat64;
  next_run_at_ms : opt nat64;
  leased_until_ms : opt nat64;
};
type SchedulerJobFailure = record {
  action : SchedulerFailureAction;
  source : SchedulerFailureSource;
  occurred_at : nat64;
  message : text;
};
type SchedulerJobKind = variant {
  SpawnExecution : record { session_id : text };
  PaymentPoll;
};
type SchedulerJobStatus = variant {
  Skipped;
  Running;
  Backoff;
  Terminal;
  Completed;
  Pending;
};
type SessionAdminView = record {
  audit : vec SessionAuditEntry;
  quote : SpawnQuote;
  quoted_total_amount : text;
  escrow_claim : EscrowClaim;
  session : SpawnSession;
  registry_record : opt SpawnedAutomatonRecord;
  pause : bool;
  runtime_record : opt AutomatonRuntimeState;
};
type SessionAuditActor = variant { System; User; Admin };
type SessionAuditEntry = record {
  actor : SessionAuditActor;
  session_id : text;
  to_state : SpawnSessionState;
  from_state : opt SpawnSessionState;
  timestamp : nat64;
  reason : text;
};
type SpawnAsset = variant { Usdc };
type SpawnChain = variant { Base };
type SpawnConfig = record {
  provider : ProviderConfig;
  chain : SpawnChain;
  risk : nat8;
  skills : vec text;
  // Repository-owned strategy IDs, not free-form labels.
  strategies : vec text;
};
type SpawnPaymentInstructions = record {
  asset : SpawnAsset;
  session_id : text;
  claim_id : text;
  chain : SpawnChain;
  quote_terms_hash : text;
  payment_address : text;
  expires_at : nat64;
  gross_amount : text;
};
type SpawnProviderSecrets = record {
  open_router_api_key : opt text;
  brave_search_api_key : opt text;
};
type SpawnQuote = record {
  asset : SpawnAsset;
  session_id : text;
  chain : SpawnChain;
  quote_terms_hash : text;
  net_forward_amount : text;
  expires_at : nat64;
  payment : SpawnPaymentInstructions;
  gross_amount : text;
  creation_cost : text;
  platform_fee : text;
};
type SpawnSession = record {
  updated_at : nat64;
  asset : SpawnAsset;
  memory_dowry : opt vec MemoryDowryFact;
  session_id : text;
  claim_id : text;
  selected_strategies : vec RepositoryStrategySessionSnapshot;
  chain : SpawnChain;
  quote_terms_hash : text;
  name : opt text;
  origin : opt SpawnSessionOrigin;
  generation : opt nat32;
  parent_constitution_hash : opt text;
  created_at : nat64;
  payment_status : PaymentStatus;
  refundable : bool;
  parent_id : opt text;
  net_forward_amount : text;
  state : SpawnSessionState;
  inherited_strategy_stats : opt vec InheritedStrategyStat;
  automaton_evm_address : opt text;
  release_broadcast : opt ReleaseBroadcastRecord;
  release_broadcast_at : opt nat64;
  royalty_allocations : opt vec RoyaltyAllocation;
  automaton_canister_id : opt text;
  constitution : opt text;
  config : SpawnConfig;
  retryable : bool;
  expires_at : nat64;
  child_ids : vec text;
  steward_address : text;
  gross_amount : text;
  last_scanned_block : opt nat64;
  release_tx_hash : opt text;
  creation_cost : text;
  platform_fee : text;
};
type SpawnSessionOrigin = variant { ReproductionOf : text; Human };
type SpawnSessionState = variant {
  Failed;
  BroadcastingRelease;
  Spawning;
  Complete;
  AwaitingPayment;
  PaymentDetected;
  Expired;
};
type SpawnSessionStatusResponse = record {
  audit : vec SessionAuditEntry;
  session : SpawnSession;
  payment : SpawnPaymentInstructions;
};
type SpawnedAutomatonRecord = record {
  evm_address : text;
  // Controller principals attested by the factory after handoff.
  controllers : opt vec text;
  session_id : text;
  // Permanent public mortality record. Starvation records may never be
  // cleared or replaced by an infrastructure restore.
  death_cause : opt text;
  chain : SpawnChain;
  name : opt text;
  canister_id : text;
  generation : opt nat32;
  constitution_hash : opt text;
  parent_constitution_hash : opt text;
  created_at : nat64;
  parent_id : opt text;
  // Exact installed ic-automaton git commit as a 40-char lowercase SHA.
  version_commit : text;
  // Required public incident log reference for infrastructure deaths.
  death_incident_reference : opt text;
  died_at : opt nat64;
  // Millisecond timestamp at which the factory verified `controllers`.
  control_verified_at : opt nat64;
  // Child canister ID for starvation, or authenticated admin principal for
  // infrastructure incidents.
  death_recorded_by : opt text;
  estate_disposition : opt text;
  royalty_allocations : opt vec RoyaltyAllocation;
  // Truthful public control label derived from the verified controller list.
  control_status : opt text;
  child_ids : vec text;
  steward_address : text;
};
type SpawnedAutomatonRegistryPage = record {
  next_cursor : opt text;
  items : vec SpawnedAutomatonRecord;
};
service : (opt FactoryInitArgs) -> {
  add_repository_strategy : (AddRepositoryStrategyRequest) -> (Result);
  // Local-evaluation clock control. Production Base deployments reject this
  // unconditionally; policy constants and admission checks remain unchanged.
  advance_evaluation_time : (nat64) -> (Result_1);
  append_artifact_chunk : (blob) -> (Result_2);
  begin_artifact_upload : (text, text, nat64) -> (Result_2);
  commit_artifact_upload : () -> (Result_3);
  create_reproduction_session : (CreateReproductionSessionRequest) -> (
      Result_4,
    );
  create_spawn_session : (CreateSpawnSessionRequest) -> (Result_4);
  deprecate_repository_strategy : (DeprecateRepositoryStrategyRequest) -> (
      Result,
    );
  derive_factory_evm_address : () -> (Result_5);
  execute_spawn_steward_command : (
      FactoryStewardCommand,
      FactoryStewardProof,
    ) -> (Result_6);
  get_artifact_upload_status : () -> (Result_2) query;
  get_factory_config : () -> (Result_7) query;
  get_factory_health : () -> (FactoryHealthSnapshot) query;
  get_factory_runtime : (nat64) -> (Result_8) query;
  get_repository_strategy : (text) -> (GetRepositoryStrategyResponse) query;
  get_reproduction_eligibility : () -> (Result_9) query;
